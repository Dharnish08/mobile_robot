<?xml version="1.0"?>
<robot name="amr_bot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ==================== ROBOT DIMENSIONS ==================== -->
  <!-- Think of these like variables in Python — define once, use everywhere -->
  <xacro:property name="base_length"     value="0.4"/>   <!-- metres -->
  <xacro:property name="base_width"      value="0.3"/>
  <xacro:property name="base_height"     value="0.15"/>
  <xacro:property name="wheel_radius"    value="0.08"/>
  <xacro:property name="wheel_thickness" value="0.04"/>
  <xacro:property name="caster_radius"   value="0.03"/>
  <xacro:property name="robot_mass"      value="10.0"/>   <!-- kg -->
  <xacro:property name="wheel_mass"      value="0.5"/>

  <!-- ==================== BASE LINK ==================== -->
  <!-- This is the main robot body — everything connects to this -->
  <link name="base_link">

    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.4 0.8 1.0"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="${robot_mass}"/>
      <inertia
        ixx="${(1/12) * robot_mass * (base_width*base_width + base_height*base_height)}"
        iyy="${(1/12) * robot_mass * (base_length*base_length + base_height*base_height)}"
        izz="${(1/12) * robot_mass * (base_length*base_length + base_width*base_width)}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>

  </link>

  <!-- ==================== LEFT WHEEL ==================== -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="${wheel_mass}"/>
      <inertia
        ixx="${(1/12) * wheel_mass * (3*wheel_radius*wheel_radius + wheel_thickness*wheel_thickness)}"
        iyy="${(1/12) * wheel_mass * (3*wheel_radius*wheel_radius + wheel_thickness*wheel_thickness)}"
        izz="${(1/2) * wheel_mass * wheel_radius*wheel_radius}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Left wheel joint — continuous means it spins freely -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="left_wheel"/>
    <!-- Position: halfway back, left side, at wheel height -->
    <origin xyz="0.0 ${base_width/2 + wheel_thickness/2} ${-base_height/2}" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ==================== RIGHT WHEEL ==================== -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="${wheel_mass}"/>
      <inertia
        ixx="${(1/12) * wheel_mass * (3*wheel_radius*wheel_radius + wheel_thickness*wheel_thickness)}"
        iyy="${(1/12) * wheel_mass * (3*wheel_radius*wheel_radius + wheel_thickness*wheel_thickness)}"
        izz="${(1/2) * wheel_mass * wheel_radius*wheel_radius}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="right_wheel"/>
    <!-- Mirror of left wheel — negative Y side -->
    <origin xyz="0.0 ${-(base_width/2 + wheel_thickness/2)} ${-base_height/2}" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ==================== CASTER WHEEL ==================== -->
  <!-- Passive wheel — no motor, just supports the front of the robot -->
  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="grey">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia
        ixx="${(2/5) * 0.1 * caster_radius*caster_radius}"
        iyy="${(2/5) * 0.1 * caster_radius*caster_radius}"
        izz="${(2/5) * 0.1 * caster_radius*caster_radius}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Fixed joint — caster doesn't move relative to base -->
  <!-- Fixed joint — caster doesn't move relative to base -->
  <joint name="caster_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="caster_wheel"/>
      <origin xyz="${base_length/2 - caster_radius} 0 
          ${-base_height/2 - (wheel_radius - caster_radius)}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== LIDAR ==================== -->
  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.06"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Fixed joint — LiDAR sits on top of robot body -->
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <origin xyz="0 0 ${base_height/2 + 0.03}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== GAZEBO PLUGINS ==================== -->

  <!-- Differential Drive Plugin -->
  <!-- This is what makes your robot actually move in simulation -->
  <gazebo>
    <plugin name="differential_drive_controller"
            filename="libgazebo_ros_diff_drive.so">

      <!-- Update rate in Hz -->
      <update_rate>50</update_rate>

      <!-- Wheel joints — must match your joint names exactly -->
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <!-- Robot geometry — must match your URDF values -->
      <wheel_separation>0.34</wheel_separation>  <!-- base_width + wheel_thickness -->
      <wheel_diameter>0.16</wheel_diameter>       <!-- 2 * wheel_radius -->

      <!-- Max wheel torque and acceleration -->
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>

      <!-- Topics this plugin reads and publishes -->
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>

      <!-- Publish TF: odom → base_link -->
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>

    </plugin>
  </gazebo>

  <!-- LiDAR Ray Sensor Plugin -->
  <!-- This makes your LiDAR actually fire laser rays and publish /scan -->
  <gazebo reference="lidar_link">
    <sensor type="ray" name="lidar_sensor">

      <!-- Position of sensor within the link -->
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>  <!-- Show laser rays in Gazebo -->
      <update_rate>10</update_rate>

      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>        <!-- 360 laser rays -->
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>  <!-- Full 360° sweep -->
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>    <!-- Minimum detection range -->
          <max>10.0</max>    <!-- Maximum detection range -->
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>   <!-- Small realistic noise -->
        </noise>
      </ray>

      <!-- ROS plugin that bridges sensor → /scan topic -->
      <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>

    </sensor>
  </gazebo>
  <!-- Remove friction from caster so it slides freely -->
  <gazebo reference="caster_wheel">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>
</robot>